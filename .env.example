# ─────────────────────────────────────────────────────────────
#  .env.example  —  Variables para docker-compose del frontend
#  Copia a .env y rellena con valores reales.
#  NUNCA commitees .env con valores reales.
# ─────────────────────────────────────────────────────────────

# URL del backend (IP privada del EC2 backend o IP pública según arquitectura)
BACKEND_URL=http://TU_IP_BACKEND:8080

# Usuario de Docker Hub
DOCKERHUB_USERNAME=tu_usuario_dockerhub
